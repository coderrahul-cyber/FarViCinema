{
  "compilerOptions": {
    "lib": ["ESNext" , "DOM"],
    "target": "ESNext",
    "module": "preserve",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node" , "bun"]
  }
  ,
  "include": ["src"]
}
